# Astro exposes only vars prefixed with PUBLIC_ to the client bundle.
PUBLIC_CONVEX_URL=

# Convex CLI writes CONVEX_URL, CONVEX_SITE_URL, and CONVEX_DEPLOYMENT when you run `npm run convex:dev`.

# Convex dashboard → Settings → Environment variables (required for Convex Auth):
# JWT_PRIVATE_KEY="..."   (run: node scripts/generate-jwt-keys.mjs)
# JWKS=...
#
# Optional: only this email may run content mutations (sign-in still works for others):
# ADMIN_EMAIL=you@example.com
