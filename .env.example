# --- Astro / Vite (this file or .env.local) ---
# Convex → Settings → URL → “Deploy to Convex” HTTP URL (no trailing slash)
PUBLIC_CONVEX_URL=

# --- Convex dashboard only: Deployment → Environment variables ---
# (Do not put JWT_PRIVATE_KEY / JWKS in .env.local — they stay in Convex.)
#
# ADMIN_EMAIL=you@example.com
# CONVEX_SITE_URL=https://YOUR_DEPLOYMENT.convex.cloud
# JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY----- ... (one line) ..."
# JWKS={"keys":[...]}
#
# Generate JWT_PRIVATE_KEY + JWKS:
#   npm run convex:setup-auth-env

# CI: Convex deploy (https://docs.convex.dev/production/hosting/cli-deploy-key)
# CONVEX_DEPLOY_KEY=
