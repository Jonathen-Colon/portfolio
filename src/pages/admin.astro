---
import AdminApp from "../components/AdminApp";
import "../styles/paper-crafts.css";
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta content="width=device-width, initial-scale=1.0" name="viewport" />
        <link rel="icon" type="image/png" href="/icon.png" />
        <title>Admin — Subscribers</title>
        <link href="https://fonts.googleapis.com" rel="preconnect" />
        <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
        <link
            href="https://fonts.googleapis.com/css2?family=Fredoka:wght@300;400;500;600;700&family=Outfit:wght@300;400;500;600;700&display=swap"
            rel="stylesheet"
        />
        <link
            href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
            rel="stylesheet"
        />
        <style is:global>
            body {
                background-color: #f9f7f1;
                min-height: 100vh;
            }
        </style>
    </head>
    <body class="font-sans text-text-dark p-6 md:p-10">
        <AdminApp client:only="react">
            <p
                slot="fallback"
                class="font-quirky text-text-light text-center py-12 max-w-md mx-auto"
            >
                Loading admin…
            </p>
        </AdminApp>
    </body>
</html>
